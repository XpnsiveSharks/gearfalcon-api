# Application
APP_ENV=development
APP_DEBUG=true

# Database
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gearfalcon
DB_USERNAME=root
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-access-key-at-least-32-characters-long-for-security
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long-different-from-access
JWT_TTL_SECONDS=900

# Cookie Configuration
COOKIE_DOMAIN=

# Email Configuration (if needed)
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# CORS Configuration
ALLOWED_ORIGIN=http://localhost:3000,http://frontend:3000