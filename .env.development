# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gearfalcon_db_dev
DB_USERNAME=root
DB_PASSWORD=

# JWT Settings
# For HS256 (default), a 32-byte is recommended JWT_SECRET 
# to do create random string for JWT_SECRET.
JWT_SECRET=your_super_secret_key_here
JWT_ALGO=HS256
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800
JWT_ISSUER=gearfalcon

# Allowed origins
ALLOWED_ORIGIN=http://localhost:3000